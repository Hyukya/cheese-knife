{
  "name": "cheese-knife",
  "version": "2.12.2",
  "description": "A CHZZK toolkit",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && cp -r _locales web styles *.html *.js *.css *.png manifest.json dist",
    "postversion": "manifest=\"$(jq \".version = `jq '.version' package.json`\" manifest.json)\" && echo \"$manifest\" > manifest.json",
    "publish:chrome": "google-chrome --headless --no-sandbox --disable-crash-reporter --no-crashpad --pack-extension=./dist --pack-extension-key=key.pem && chrome-webstore-upload --source=dist.crx",
    "publish:firefox": "cd dist && web-ext sign --channel listed --approval-timeout 60000"
  },
  "devDependencies": {
    "chrome-webstore-upload-cli": "^4.0.0-0",
    "web-ext": "^10.1.0"
  }
}
